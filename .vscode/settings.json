{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit", // Automatically fix ESLint issues on save
    "source.organizeImports": "explicit" // Automatically sort and remove unused imports
  },
  "editor.formatOnSave": true, // Format files automatically on save (Prettier)
  "prettier.requireConfig": true, // Only run Prettier if a config file exists
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode" // Use Prettier for CSS
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode" // Use Prettier for JavaScript
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode" // Use Prettier for JSON
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode" // Use Prettier for TypeScript
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode" // Use Prettier for TSX
  },
}
